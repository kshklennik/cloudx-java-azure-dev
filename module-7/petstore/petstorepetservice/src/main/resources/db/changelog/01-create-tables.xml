<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="Kazimir_ShkLENNIK">
        <createTable tableName="category">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)"/>
        </createTable>

        <createTable tableName="tag">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)"/>
        </createTable>

        <createTable tableName="pet">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="photo_url" type="varchar(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(50)"/>
            <column name="category_id" type="bigint">
                <constraints foreignKeyName="fk_pet_category" referencedTableName="category" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createTable tableName="pet_tags">
            <column name="pet_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_pet_tags_pet" referencedTableName="pet" referencedColumnNames="id"/>
            </column>
            <column name="tags_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_pet_tags_tag" referencedTableName="tag" referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
